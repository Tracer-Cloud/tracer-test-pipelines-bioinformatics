// Nextflow configuration file for Pixi-managed environment (Linux ARM64)

// Pipeline metadata
manifest {
    name = 'minimal-pixi-pipeline-linux-arm64'
    description = 'Minimal Nextflow pipeline using Pixi for dependency management (Linux ARM64)'
    version = '1.0.0'
    nextflowVersion = '>=24.10.0'
    author = 'Tracer Bioinformatics Team'
}

// Pixi environment configuration
// Note: Pixi manages the environment, so we don't need conda configuration
// All dependencies are available in the Pixi environment

// Process configuration
process {
    // No conda environment needed - Pixi handles this
    // All tools are available in the current environment
    
    // Resource requirements (optimized for ARM64)
    cpus = 2
    memory = '4 GB'
    time = '1 h'

    // Capture process logs
    errorStrategy = 'retry'
    maxRetries = 1

    // Process-specific configurations
    withName: CHECK_VERSIONS {
        cpus = 1
        memory = '1 GB'
        time = '10 min'
    }

    withName: FASTQC_ANALYSIS {
        cpus = 2
        memory = '2 GB'
        time = '30 min'
    }

    withName: STAR_INFO {
        cpus = 1
        memory = '1 GB'
        time = '5 min'
    }

    withName: FASTA_STATS {
        cpus = 1
        memory = '2 GB'
        time = '15 min'
    }
}

// Default parameters
params {
    input = "test_data/*.fasta"
    outdir = "results"
    logsdir = "logs"
    help = false
}

// Logging configuration
log {
    enabled = true
    file = "${params.logsdir}/nextflow.log"
}

// Trace, Report, and Timeline configurations
trace {
    enabled = true
    file = "${params.logsdir}/trace.txt"
    overwrite = true
}

report {
    enabled = true
    file = "${params.logsdir}/pipeline_report.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.logsdir}/timeline.html"
    overwrite = true
}

// Environment variables to ensure logs go to the right place
env {
    NXF_LOG_FILE = "${params.logsdir}/nextflow.log"
    // Pixi ensures all tools are in PATH
    PIXI_PLATFORM = "linux-aarch64"
}

// Profiles for different execution modes
profiles {
    standard {
        process.executor = 'local'
    }
    
    debug {
        process.echo = true
        trace.enabled = true
        report.enabled = true
        timeline.enabled = true
    }
    
    fast {
        process {
            cpus = 4
            memory = '8 GB'
        }
    }
    
    // ARM64 optimized profile
    arm64 {
        process {
            cpus = { task.attempt == 1 ? 2 : 4 }
            memory = { task.attempt == 1 ? '4 GB' : '8 GB' }
        }
        
        // ARM64 specific optimizations
        env {
            OMP_NUM_THREADS = '2'
            PIXI_PLATFORM = "linux-aarch64"
        }
    }
}

// Workflow completion message
workflow.onComplete {
    log.info """
    ===================================
    Pipeline Execution Summary (Linux ARM64)
    ===================================
    Workflow Version : ${workflow.manifest.version}
    Nextflow Version : ${workflow.nextflow.version}
    Command Line     : ${workflow.commandLine}
    Duration         : ${workflow.duration}
    Success          : ${workflow.success}
    Exit Status      : ${workflow.exitStatus}
    Error Report     : ${workflow.errorReport ?: 'None'}
    Launch Directory : ${workflow.launchDir}
    Work Directory   : ${workflow.workDir}
    Project Directory: ${workflow.projectDir}
    Architecture     : Linux ARM64
    Package Manager  : Pixi
    ===================================
    Output Directory : ${params.outdir}
    Logs Directory   : ${params.logsdir}
    ===================================
    """.stripIndent()
    
    if (workflow.success) {
        log.info "Pipeline completed successfully on Linux ARM64!"
        log.info "Results are available in: ${params.outdir}"
        log.info "Logs are available in: ${params.logsdir}"
    } else {
        log.error "Pipeline failed on Linux ARM64!"
        log.error "Check the error report above and logs in: ${params.logsdir}"
    }
}
